        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n  autonumber\n  actor Cliente\n  participant Frontend\n  participant CTRL as Controlador\n  participant SVC as Servicio&lt;br/&gt;Pago\n  participant EF as Entidad&lt;br/&gt;Financiera\n  participant MySQL as database\n\n  Cliente-&gt;&gt;Frontend: Confirmar pago\n  Frontend-&gt;&gt;CTRL: POST /pago {factura, metodo, monto}\n  activate CTRL\n  CTRL-&gt;&gt;SVC: procesarPago(datos)\n  activate SVC\n  SVC-&gt;&gt;MySQL: SELECT FacturaCabecera WHERE id=X\n  MySQL--&gt;&gt;SVC: factura válida\n  SVC-&gt;&gt;EF: Autorizar transacción\n  activate EF\n  EF--&gt;&gt;SVC: Pago aprobado / token\n  deactivate EF\n  SVC-&gt;&gt;MySQL: INSERT INTO Pago\n  MySQL--&gt;&gt;SVC: idPago OK\n  SVC-&gt;&gt;MySQL: UPDATE PedidoCabecera SET estadoPedido=&#39;Procesado&#39;\n  MySQL--&gt;&gt;SVC: OK\n  deactivate SVC\n  CTRL--&gt;&gt;Frontend: HTTP 200 {pago confirmado}\n  deactivate CTRL\n  Frontend--&gt;&gt;Cliente: Mostrar confirmación + factura PDF\n\n  alt Pago rechazado\n    EF--&gt;&gt;SVC: Rechazado\n    SVC--&gt;&gt;CTRL: Error 402\n    CTRL--&gt;&gt;Frontend: HTTP 402 &#39;pago rechazado&#39;\n    Frontend--&gt;&gt;Cliente: Solicitar otro método de pago\n  end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="53">
