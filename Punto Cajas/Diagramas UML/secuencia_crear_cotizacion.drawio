        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n  autonumber\n  actor Cliente\n  participant Frontend\n  participant Controlador\n  participant Servicio\n  participant BD as Base de Datos\n\n  Cliente-&gt;&gt;Frontend: Clic \&quot;Crear cotización\&quot;\n  activate Frontend\n  Frontend-&gt;&gt;Controlador: POST /cotizacion {datos}\n  deactivate Frontend\n  activate Controlador\n  Controlador-&gt;&gt;Servicio: crearCotizacion()\n  deactivate Controlador\n  activate Servicio\n  Servicio-&gt;&gt;BD: SELECT Usuario\n  activate BD\n  BD--&gt;&gt;Servicio: Usuario válido\n  deactivate BD\n  Servicio-&gt;&gt;BD: INSERT Cotización\n  activate BD\n  BD--&gt;&gt;Servicio: id_cotizacion = 42\n  deactivate BD\n  Servicio-&gt;&gt;BD: Calcular IVA / Total\n  activate BD\n  BD--&gt;&gt;Servicio: subtotal, total OK\n  deactivate BD\n  Servicio--&gt;&gt;Controlador: cotizacion {id,total}\n  deactivate Servicio\n  activate Controlador\n  Controlador--&gt;&gt;Frontend: HTTP 201 {cotizacion}\n  deactivate Controlador\n  activate Frontend\n  Frontend--&gt;&gt;Cliente: Mostrar cotización\n  deactivate Frontend\n\n  alt Stock insuficiente\n    Servicio--&gt;&gt;Controlador: HTTP 400 \&quot;Sin stock\&quot;\n    activate Controlador\n    Controlador--&gt;&gt;Frontend: Mostrar error\n    deactivate Controlador\n    activate Frontend\n    Frontend--&gt;&gt;Cliente: Mostrar error al usuario\n    deactivate Frontend\n  end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="54">
